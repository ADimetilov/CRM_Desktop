<Page x:Class="CRM.Analitic"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CRM"
      mc:Ignorable="d"
      Title="Analitic" Height="1000" Width="1590">

    <Grid Height="1000" Width="1590" Background="White">
        <Label Content="Аналитика и отчетность" HorizontalAlignment="Left" Margin="558,21,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold" FontSize="24"/>
        <Rectangle HorizontalAlignment="Left" Height="78" Margin="50,88,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="448"/>
        <Label Content="Подразделение" HorizontalAlignment="Left" Margin="70,110,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <ComboBox x:Name="OrganizationBox" HorizontalAlignment="Left" Margin="204,115,0,0" VerticalAlignment="Top" Width="271" Height="24" DisplayMemberPath="name" SelectedItem="{Binding Path = Organization}" SelectedValue="{Binding Path=Organization.id}" SelectedValuePath="id"/>
        <Rectangle HorizontalAlignment="Left" Height="85" Margin="50,189,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="448"/>
        <Label Content="Услуга" HorizontalAlignment="Left" Margin="72,206,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <ComboBox x:Name="ServiceBox" HorizontalAlignment="Left" Margin="204,208,0,0" VerticalAlignment="Top" Width="271" Height="24" DisplayMemberPath="name" SelectedItem="{Binding Path = Service}" SelectedValue="{Binding Path=Service.id}" SelectedValuePath="id">
        </ComboBox>
        <CheckBox Content="Все" HorizontalAlignment="Left" Margin="75,237,0,0" VerticalAlignment="Top" Width="40" Height="16" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Rectangle HorizontalAlignment="Left" Height="138" Margin="50,502,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="448"/>
        <Label Content="Дата начала" HorizontalAlignment="Left" Margin="75,538,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <DatePicker HorizontalAlignment="Left" Margin="204,539,0,0" VerticalAlignment="Top" SelectedDateFormat="Short" Height="24" Width="271"/>
        <Label Content="Дата окончания" HorizontalAlignment="Left" Margin="75,589,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <DatePicker HorizontalAlignment="Left" Margin="204,590,0,0" VerticalAlignment="Top" SelectedDateFormat="Short" Height="24" Width="271"/>
        <Button Content="Сформировать" HorizontalAlignment="Left" Margin="161,0,0,132" VerticalAlignment="Bottom" Height="38" Width="204" Foreground="White" Background="#FF2B6CB0" FontSize="16" FontWeight="Bold"/>
        <CheckBox Content="Все" HorizontalAlignment="Left" Margin="75,141,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Rectangle HorizontalAlignment="Left" Height="84" Margin="50,292,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="448"/>
        <Label Content="Статус" HorizontalAlignment="Left" Margin="72,311,0,0" VerticalAlignment="Top" Width="49" Foreground="#FF1A365D" FontWeight="Bold"/>
        <ComboBox x:Name="StatusBox" HorizontalAlignment="Left" Margin="204,313,0,0" VerticalAlignment="Top" Width="271" Height="24" DisplayMemberPath="status" SelectedItem="{Binding Path = Status}" SelectedValue="{Binding Path=Status.id}" SelectedValuePath="id">
        </ComboBox>
        <Rectangle HorizontalAlignment="Left" Height="84" Margin="50,394,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="448"/>
        <Label Content="Ответственный" HorizontalAlignment="Left" Margin="72,423,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <ComboBox x:Name="UserBox" HorizontalAlignment="Left" Margin="204,424,0,0" VerticalAlignment="Top" Width="271" Height="24" DisplayMemberPath="fio" SelectedItem="{Binding Path = User}" SelectedValue="{Binding Path=User.id}" SelectedValuePath="id">
        </ComboBox>
        <Label Content="Параметры" HorizontalAlignment="Left" Margin="224,52,0,0" VerticalAlignment="Top" FontSize="16" Foreground="#FF718096" FontWeight="Bold"/>
        <Rectangle HorizontalAlignment="Left" Height="236" Margin="608,88,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="874"/>
        <Label Content="Данные" HorizontalAlignment="Left" Margin="1008,52,0,0" VerticalAlignment="Top" FontSize="16" Foreground="#FF718096" FontWeight="Bold"/>
        <CheckBox Content="Все" HorizontalAlignment="Left" Margin="75,343,0,0" VerticalAlignment="Top" Width="40" Height="16" Foreground="#FF1A365D" FontWeight="Bold"/>
        <DataGrid d:ItemsSource="{d:SampleData ItemCount=5}" Margin="608,351,108,132">
        </DataGrid>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" Margin="608,88,108,676">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <TextBlock>
                            <Run Text="{Binding Path=field}"></Run>
                            <Run Text="|"></Run>
                            <Run Text="{Binding Path=value}"></Run>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</Page>
