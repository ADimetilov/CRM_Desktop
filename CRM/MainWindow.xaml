<Window x:Class="CRM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800">
    <Grid>
        <Rectangle Stroke="#FFE2E8F0" Margin="141,75,141,47"/>

        <Label Content="Авторизация" HorizontalAlignment="Center" Margin="0,95,0,0" VerticalAlignment="Top" FontSize="20" FontWeight="Bold" Foreground="#FF1A365D"/>
        <Label Content="Добро пожаловать в СВМПМО" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="36" FontWeight="Bold" Foreground="#FF1A365D"/>
        <Label Content="Логин" HorizontalAlignment="Left" Margin="225,150,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <TextBox x:Name="uLogin" HorizontalAlignment="Left" Margin="331,150,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="255" Height="35" FontSize="20"/>
        <PasswordBox x:Name="uPassword" HorizontalAlignment="Left" Margin="331,213,0,0" VerticalAlignment="Top" Width="255" Height="37" FontSize="20"/>
        <Label Content="Пароль" HorizontalAlignment="Left" Margin="221,213,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Button Content="Войти" HorizontalAlignment="Center" Margin="0,297,0,0" VerticalAlignment="Top" Height="40" Width="150"  Background="#FF1A365D" Foreground="White" FontWeight="Bold" Click="Button_Click" />
        <Button Content="" HorizontalAlignment="Left" Template="{StaticResource NoMouseOverButtonTemplate}" Margin="750,15,0,0" VerticalAlignment="Top" Height="35" Width="36" BorderBrush="{x:Null}" Foreground="White" Click="Button_Click_1" RenderTransformOrigin="0.5,0.5">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="0.18"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
            <Button.Background>
                <ImageBrush ImageSource="/hyperlink-svg-icon.png" Stretch="Fill"/>
            </Button.Background>
        </Button>

    </Grid>
</Window>
