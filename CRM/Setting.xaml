<Window x:Class="CRM.Setting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM"
        mc:Ignorable="d"
        Height="327" Width="313"
        Title="Настройки" MaxHeight="327" MaxWidth="313">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <TextBox x:Name="ip_adress" HorizontalAlignment="Center" Margin="83,46,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="204" Height="23" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Label Content="Сервер" HorizontalAlignment="Left" Margin="10,43,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Button Content="Сохранить" HorizontalAlignment="Center" Margin="0,0,0,20" VerticalAlignment="Bottom" Height="26" Width="107" Background="#FF1A365D" Foreground="White" BorderBrush="{x:Null}" Click="Button_Click"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,3,0,0" TextWrapping="Wrap" Text="Настройки" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>

    </Grid>
</Window>
