<Page x:Class="CRM.SubOrganization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CRM"
      mc:Ignorable="d"
      Title="SubOrganization"  Height="1000" Width="1590">

    <Grid Background="White"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Height="1000" Width="1590">
        <Label Content="Подразделение" HorizontalAlignment="Left" Margin="558,21,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold" FontSize="24"/>
        <Label Content="Наименование:" HorizontalAlignment="Left" Margin="47,69,0,0" VerticalAlignment="Top" Height="28" Width="101" Foreground="#FF1A365D" FontWeight="Bold"/>
        <TextBlock HorizontalAlignment="Left" Margin="153,74,0,0" TextWrapping="Wrap" VerticalAlignment="Top">
            <Run Text="{Binding Path=name}"></Run>
        </TextBlock>
        <Rectangle HorizontalAlignment="Left" Height="38" Margin="47,64,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="278"/>
        <Rectangle HorizontalAlignment="Left" Height="311" Margin="47,123,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="278"/>
        <Label Content="Описание:" Margin="51,128,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="28" Foreground="#FF1A365D" FontWeight="Bold" Width="274" BorderBrush="Black"/>
        <Rectangle HorizontalAlignment="Left" Height="365" Margin="1155,69,0,0" Stroke="#FFE2E8F0" VerticalAlignment="Top" Width="349"/>
        <Label Content="Персонал" HorizontalAlignment="Left" Margin="1296,74,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Label Content="Всего:" HorizontalAlignment="Left" Margin="1172,110,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Label Content="Активные:" HorizontalAlignment="Left" Margin="1172,148,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>
        <Label Content="Не активные:" HorizontalAlignment="Left" Margin="1172,191,0,0" VerticalAlignment="Top" Foreground="#FF1A365D" FontWeight="Bold"/>

    </Grid>
</Page>
